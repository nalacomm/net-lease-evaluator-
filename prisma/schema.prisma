generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Auth (single user: Ed) ----------
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String // bcrypt hash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Core domain ----------
model Investor {
  id         String    @id @default(cuid())
  name       String
  email      String?
  phone      String?
  entityName String?
  notes      String?
  buyBox      BuyBox?
  deals       Deal[]
  reports     Report[]
  assignments DealAssignment[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model BuyBox {
  id         String   @id @default(cuid())
  investorId String   @unique
  investor   Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  // Cap Rate
  capRateMin    Float
  capRateTarget Float

  // Price
  priceMax     Float
  priceStretch Float?

  // Lease
  leaseTypePreferred  String
  leaseTypeAcceptable String

  // Term
  termMinYears       Int
  termPreferredYears Int?

  // Rent Bumps
  bumpMinPercent   Float?
  bumpAltStructure String?
  flatLeaseAllowed Boolean @default(false)

  // Guaranty
  guarantyPreferred  String
  guarantyAcceptable String
  guarantyFloor      String

  // Operator
  operatorMinUnits Int?

  // Underwriting
  dscrMin          Float
  ltv              Float
  interestRate     Float
  amortizationYears Int

  // Construction
  constructionPreferred String?

  // Demographics
  hhiMin Float?

  // Asset Types
  assetTypesPreferred  String[]
  assetTypesAcceptable String[]

  // Location Preferences
  preferredStates String[]
  targetMarkets   String[]

  // Cash Flow
  currentMonthlyIncome Float?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deal {
  id         String    @id @default(cuid())
  // Nullable — deals live in a global pool; investorId is the "primary" investor
  investorId String?
  investor   Investor? @relation(fields: [investorId], references: [id], onDelete: SetNull)

  // Property
  address   String?
  city      String?
  state     String?
  quadrant  String?
  assetType String?

  // Tenant
  tenantName        String?
  operatorName      String?
  operatorUnitCount Int?
  guarantyType      String?

  // Financials
  askingPrice         Float?
  noi                 Float?
  capRateAsking       Float?
  capRateUnderwritten Float?

  // Lease
  leaseType           String?
  termRemainingYears  Float?
  leaseCommenceDate   DateTime?
  leaseExpirationDate DateTime?
  bumpStructure       String?
  bumpPercent         Float?

  // Construction
  constructionYear Int?
  buildingSize     Float?
  lotSize          Float?

  // Shopping Center specific
  numberOfTenants   Int?
  anchorTenant      String?
  vacancyRate       Float?    // percent, e.g. 5.0
  grossLeasableArea Float?    // total GLA in SF

  // Demographics
  hhi1Mile        Float?
  hhi3Mile        Float?
  hhi5Mile        Float?
  population1Mile Int?

  // Calculated (against primary investor buy box)
  dscrCalculated     Float?
  loanAmount         Float?
  monthlyDebtService Float?
  monthlyNetCashFlow Float?

  // Scoring (against primary investor buy box)
  score            Float?
  grade            String?
  scoreRationale   String?
  scoreBreakdown   Json?
  confidenceLevel  String?
  selfCheckerNotes  String?
  analysisContext   String?

  // Source
  sourceType     String?
  sourceBroker   String?
  sourcePlatform String?
  sourceUrl      String?

  // Status
  status String @default("active")

  updates     DealUpdate[]
  newsFlags   DealNewsFlag[]
  assignments DealAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-investor scoring for deals shared across investors
model DealAssignment {
  id         String   @id @default(cuid())
  dealId     String
  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  investorId String
  investor   Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  score          Float?
  grade          String?
  scoreBreakdown Json?
  gapAnalysis    Json?   // cached result from runGapAnalysis — persists so it doesn't need re-running

  createdAt      DateTime @default(now())

  @@unique([dealId, investorId])
}

model DealUpdate {
  id            String   @id @default(cuid())
  dealId        String
  deal          Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  content       String
  sourceType    String
  aiAnalysis    String?
  fieldsUpdated String[]
  previousScore Float?
  newScore      Float?
  createdAt     DateTime @default(now())
}

model NewsItem {
  id          String         @id @default(cuid())
  headline    String
  summary     String?
  source      String?
  url         String?
  publishedAt DateTime?
  category    String?
  rawContent  String?
  dealFlags   DealNewsFlag[]
  siteFlags   SiteNewsFlag[]
  createdAt   DateTime       @default(now())
}

model DealNewsFlag {
  id         String   @id @default(cuid())
  dealId     String
  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  newsItemId String
  newsItem   NewsItem @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  relevance  String?
  impact     String?
  createdAt  DateTime @default(now())
}

model Report {
  id          String   @id @default(cuid())
  investorId  String
  investor    Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  title       String?
  dealIds     String[]
  generatedAt DateTime @default(now())
  pdfUrl      String?
  reportData  Json?
}

model SiteReport {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String?
  siteIds     String[]
  generatedAt DateTime @default(now())
  reportData  Json?
}

model Comp {
  id            String    @id @default(cuid())
  dealId        String?
  address       String?
  assetType     String?
  tenantName    String?
  salePrice     Float?
  capRate       Float?
  pricePerSF    Float?
  termRemaining Float?
  closedAt      DateTime?
  source        String?
  notes         String?
  createdAt     DateTime  @default(now())
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  company   String?
  contact   String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requirements    TenantRequirements?
  siteAssignments SiteAssignment[]
  campaigns       Campaign[]
  siteReports     SiteReport[]
}

model TenantRequirements {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  minSF          Float?
  maxSF          Float?
  preferredSF    Float?
  minRentPsf     Float?
  maxRentPsf     Float?
  leaseType      String?
  minParking     Float?
  minTraffic     Int?
  minPopulation  Int?
  minIncome      Int?
  radiusMiles    Float?
  minTerm        Int?
  preferredTerm  Int?
  targetMarkets  String[]
  coTenancy      String?
  exclusivity    String?
  zoningReqs     String?
  siteTypePrefs  String[]
  additionalNotes String?
  rawInput        String?
  inferredFields  String[]
  missingFields   String[]
  confidenceLevel String?
  narrativeSummary String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProspectiveSite {
  id    String @id @default(cuid())
  name  String
  address  String?
  city     String?
  state    String?
  zip      String?
  quadrant String?

  squareFeet       Float?
  parkingSpaces    Int?
  parkingRatio     Float?
  siteType         String?

  askingRentPsf    Float?
  nnnEstimate      Float?
  leaseType        String?
  leaseTermOffered Int?

  dailyTraffic  Int?
  population1mi Int?
  population3mi Int?
  population5mi Int?
  medianIncome  Float?

  coTenants     String?
  zoning        String?
  availableDate String?

  source      String?
  brokerName  String?
  brokerEmail String?
  brokerPhone String?

  notes  String?
  status String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments SiteAssignment[]
  newsFlags   SiteNewsFlag[]
}

model SiteAssignment {
  id       String @id @default(cuid())
  siteId   String
  tenantId String
  site     ProspectiveSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  score          Float?
  grade          String?
  scoreBreakdown Json?
  gapAnalysis    Json?
  gapHistory     Json?
  gapContext     String?
  scoringConfig  Json?   // { enabledCategories: string[] }

  createdAt DateTime @default(now())

  @@unique([siteId, tenantId])
}

model SiteNewsFlag {
  id         String @id @default(cuid())
  siteId     String
  site       ProspectiveSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  newsItemId String
  newsItem   NewsItem @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  relevance  String?
  impact     String?
  createdAt  DateTime @default(now())
}

model Campaign {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title    String
  html     String
  createdAt DateTime @default(now())
}
