# Neon Postgres (Vercel-provisioned)
# Pooled connection for the app runtime
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/net_lease_evaluator?sslmode=require"
# Direct (non-pooler) connection for Prisma migrations
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/net_lease_evaluator?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# Single-user admin (Ed)
ADMIN_EMAIL="ed@blakedickson.com"
ADMIN_PASSWORD="set-a-strong-password"
